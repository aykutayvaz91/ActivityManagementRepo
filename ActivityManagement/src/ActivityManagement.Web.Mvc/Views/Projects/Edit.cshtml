@model ActivityManagement.Projects.Dto.CreateUpdateProjectDto
@{
    ViewData["Title"] = "Proje Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var employees = ViewBag.Employees as IList<ActivityManagement.Employees.Dto.EmployeeDto>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Projects">Projeler</a></li>
            <li class="breadcrumb-item active">Düzenle</li>
        </ol>
    </nav>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Proje Düzenle</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label">Proje Adı <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Code" class="form-label">Proje Kodu <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">Başlangıç Tarihi</label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PlannedEndDate" class="form-label">Planlanan Bitiş</label>
                            <input asp-for="PlannedEndDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label">Durum</label>
                            <select asp-for="Status" class="form-select">
                                <option value="0">Planlandı</option>
                                <option value="1">Devam Ediyor</option>
                                <option value="2">Tamamlandı</option>
                                <option value="3">İptal</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label">Öncelik</label>
                            <select asp-for="Priority" class="form-select">
                                <option value="1">Düşük</option>
                                <option value="2">Normal</option>
                                <option value="3">Yüksek</option>
                                <option value="4">Kritik</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ManagerId" class="form-label">Proje Yöneticisi</label>
                            <select asp-for="ManagerId" class="form-select">
                                <option value="">Seçiniz...</option>
                                @if (employees != null)
                                {
                                    foreach (var emp in employees)
                                    {
                                        <option value="@emp.Id">@emp.FullName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/Projects" class="btn btn-outline-secondary">İptal</a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save me-1"></i>Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
