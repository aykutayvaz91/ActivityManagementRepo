@model ActivityManagement.Reports.Dto.PersonalReportDto
@{
    ViewData["Title"] = $"{Model.EmployeeName} - Faaliyet Raporu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Reports/Personal">Kişisel Rapor</a></li>
            <li class="breadcrumb-item active">@Model.EmployeeName</li>
        </ol>
    </nav>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-print me-1"></i>Yazdır
        </button>
        <button onclick="exportReport()" class="btn btn-success btn-sm">
            <i class="fas fa-file-excel me-1"></i>Excel
        </button>
    </div>
</div>

<!-- Özet Kartlar -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <i class="fas fa-clock fa-2x mb-2"></i>
                <div class="h3 mb-0">@Model.TotalHours.ToString("F1")</div>
                <small>Toplam Saat</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <i class="fas fa-list fa-2x mb-2"></i>
                <div class="h3 mb-0">@Model.TotalActivities</div>
                <small>Faaliyet Sayısı</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <i class="fas fa-check-circle fa-2x mb-2"></i>
                <div class="h3 mb-0">@Model.CompletedTaskCount</div>
                <small>Tamamlanan Görev</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body text-center">
                <i class="fas fa-hourglass-half fa-2x mb-2"></i>
                <div class="h3 mb-0">@Model.PendingTaskCount</div>
                <small>Bekleyen Görev</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Personel Bilgisi -->
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="fas fa-user me-2 text-primary"></i>Personel Bilgisi</h6>
            </div>
            <div class="card-body small">
                <table class="table table-borderless table-sm mb-0">
                    <tr><td class="text-muted">Ad Soyad:</td><td><strong>@Model.EmployeeName</strong></td></tr>
                    <tr><td class="text-muted">Unvan:</td><td>@Model.Title</td></tr>
                    <tr><td class="text-muted">Departman:</td><td>@Model.Department</td></tr>
                    <tr><td class="text-muted">Dönem:</td><td>@Model.StartDate.ToString("dd.MM.yyyy") - @Model.EndDate.ToString("dd.MM.yyyy")</td></tr>
                </table>
            </div>
        </div>

        <!-- Proje Özeti -->
        @if (Model.ProjectSummaries.Any())
        {
            <div class="card shadow-sm">
                <div class="card-header bg-transparent">
                    <h6 class="mb-0"><i class="fas fa-project-diagram me-2 text-info"></i>Proje Dağılımı</h6>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var p in Model.ProjectSummaries.OrderByDescending(x => x.TotalHours))
                    {
                        <li class="list-group-item small">
                            <div class="d-flex justify-content-between">
                                <span><strong>@p.ProjectName</strong></span>
                                <span class="badge bg-primary">@p.TotalHours.ToString("F1") s</span>
                            </div>
                            <small class="text-muted">@p.CompletedTaskCount / @p.TaskCount görev tamamlandı</small>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <!-- Günlük Faaliyetler -->
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="fas fa-calendar-check me-2 text-success"></i>Günlük Faaliyet Özeti</h6>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Gün</th>
                            <th>Faaliyet</th>
                            <th>Süre</th>
                            <th>Açıklamalar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var day in Model.DailyActivities.OrderByDescending(d => d.Date))
                        {
                            <tr>
                                <td><strong>@day.Date.ToString("dd.MM.yyyy")</strong></td>
                                <td><small class="text-muted">@day.Date.ToString("dddd", new System.Globalization.CultureInfo("tr-TR"))</small></td>
                                <td><span class="badge bg-light text-dark">@day.ActivityCount</span></td>
                                <td><span class="badge bg-primary">@day.Hours.ToString("F1") s</span></td>
                                <td>
                                    <small class="text-muted">
                                        @string.Join("; ", day.Descriptions.Take(2))
                                        @if (day.Descriptions.Count > 2) { <span>+@(day.Descriptions.Count - 2) daha</span> }
                                    </small>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary">
                        <tr>
                            <td colspan="3"><strong>Toplam</strong></td>
                            <td><strong>@Model.TotalHours.ToString("F1") s</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Görevler -->
        @if (Model.TaskSummaries.Any())
        {
            <div class="card shadow-sm">
                <div class="card-header bg-transparent">
                    <h6 class="mb-0"><i class="fas fa-tasks me-2 text-warning"></i>Görev Durumu</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Görev</th><th>Durum</th><th>Öncelik</th><th>Son Tarih</th><th>%</th><th>Süre</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.TaskSummaries)
                            {
                                <tr>
                                    <td><small>@t.Title</small></td>
                                    <td><span class="badge bg-secondary" style="font-size:0.7rem">@t.Status</span></td>
                                    <td><span class="badge bg-light text-dark" style="font-size:0.7rem">@t.Priority</span></td>
                                    <td><small>@(t.DueDate.HasValue ? t.DueDate.Value.ToString("dd.MM") : "-")</small></td>
                                    <td>
                                        <div class="progress" style="width:50px;height:5px">
                                            <div class="progress-bar" style="width:@t.CompletionPercentage%"></div>
                                        </div>
                                    </td>
                                    <td><small>@t.ActualHours s</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function exportReport() {
    alert('Excel export özelliği: ClosedXML veya EPPlus kütüphanesi ile entegre edilebilir.');
}
</script>
}
