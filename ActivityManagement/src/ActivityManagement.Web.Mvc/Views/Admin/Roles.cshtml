@model IReadOnlyList<ActivityManagement.Employees.Dto.EmployeeDto>
@{
    ViewData["Title"] = "Rol Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = new[] { "Admin", "TakımLideri", "Uzman" };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/Admin">Admin Panel</a></li>
        <li class="breadcrumb-item active">Rol Yönetimi</li>
    </ol></nav>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success py-2"><i class="fas fa-check-circle me-1"></i>@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-header bg-transparent"><h6 class="mb-0"><i class="fas fa-user-tag me-2 text-primary"></i>Çalışan Rolleri</h6></div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Ad Soyad</th><th>Unvan</th><th>E-posta</th><th>Departman</th><th style="width:320px">Rol</th></tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td><strong>@e.FullName</strong></td>
                        <td><small>@e.Title</small></td>
                        <td><small class="text-muted">@e.Email</small></td>
                        <td><small>@e.Department</small></td>
                        <td>
                            <form asp-action="SetRole" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id" />
                                <select name="appRole" class="form-select form-select-sm">
                                    @foreach (var r in roles)
                                    {
                                        if (e.AppRole == r)
                                        {
                                            <option value="@r" selected>@r</option>
                                        }
                                        else
                                        {
                                            <option value="@r">@r</option>
                                        }
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary">Kaydet</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<p class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i>Admin rolü: tüm yönetim işlemleri + görev oluşturma/atama. Rol değişikliği kullanıcının bir sonraki girişinde geçerli olur.</p>
