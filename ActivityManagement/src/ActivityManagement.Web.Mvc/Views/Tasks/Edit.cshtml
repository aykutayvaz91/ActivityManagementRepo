@model ActivityManagement.Tasks.Dto.CreateUpdateTaskItemDto
@{
    ViewData["Title"] = "Görev Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var employees = ViewBag.Employees as IList<ActivityManagement.Employees.Dto.EmployeeDto>;
    var projects = ViewBag.Projects as IList<ActivityManagement.Projects.Dto.ProjectDto>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Tasks">Görevler</a></li>
            <li class="breadcrumb-item active">Düzenle</li>
        </ol>
    </nav>
</div>

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Görev Düzenle</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label">Görev Başlığı <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProjectId" class="form-label">Proje</label>
                            <select asp-for="ProjectId" class="form-select">
                                <option value="">Seçiniz...</option>
                                @if (projects != null)
                                {
                                    foreach (var p in projects)
                                    {
                                        <option value="@p.Id">[@p.Code] @p.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AssignedEmployeeId" class="form-label">Atanan Kişi</label>
                            <select asp-for="AssignedEmployeeId" class="form-select">
                                <option value="">Seçiniz...</option>
                                @if (employees != null)
                                {
                                    foreach (var e in employees)
                                    {
                                        <option value="@e.Id">@e.FullName - @e.Title</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Status" class="form-label">Durum</label>
                            <select asp-for="Status" class="form-select">
                                <option value="0">Beklemede</option>
                                <option value="1">Devam Ediyor</option>
                                <option value="2">Tamamlandı</option>
                                <option value="3">İptal</option>
                                <option value="4">Ertelendi</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Priority" class="form-label">Öncelik</label>
                            <select asp-for="Priority" class="form-select">
                                <option value="0">Düşük</option>
                                <option value="1">Normal</option>
                                <option value="2">Yüksek</option>
                                <option value="3">Kritik</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="DueDate" class="form-label">Son Tarih</label>
                            <input asp-for="DueDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="EstimatedHours" class="form-label">Tahmini Süre (s)</label>
                            <input asp-for="EstimatedHours" class="form-control" type="number" step="0.5" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ActualHours" class="form-label">Gerçek Süre (s)</label>
                            <input asp-for="ActualHours" class="form-control" type="number" step="0.5" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CompletionPercentage" class="form-label">Tamamlanma %</label>
                            <input asp-for="CompletionPercentage" class="form-control" type="number" min="0" max="100" />
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/Tasks" class="btn btn-outline-secondary">İptal</a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save me-1"></i>Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
