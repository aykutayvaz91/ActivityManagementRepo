@{
    Layout = null;
    var returnUrl = ViewBag.ReturnUrl as string ?? "/";
    var googleEnabled = ViewBag.GoogleEnabled as bool? ?? false;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş - Faaliyet Yönetim Sistemi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%); min-height: 100vh; display: flex; align-items: center; }
        .login-card { max-width: 420px; width: 100%; border: none; border-radius: 1rem; }
        .brand-icon { width: 64px; height: 64px; border-radius: 16px; background: linear-gradient(135deg,#0d6efd,#6610f2); color:#fff; display:flex; align-items:center; justify-content:center; font-size:1.8rem; margin:0 auto 1rem; }
        .btn-google { background:#fff; border:1px solid #dadce0; color:#3c4043; font-weight:500; }
        .btn-google:hover { background:#f8f9fa; }
    </style>
</head>
<body>
    <div class="container">
        <div class="d-flex justify-content-center">
            <div class="card shadow-lg login-card">
                <div class="card-body p-4 p-md-5">
                    <div class="brand-icon"><i class="fas fa-tasks"></i></div>
                    <h4 class="text-center mb-1">Faaliyet Yönetim Sistemi</h4>
                    <p class="text-center text-muted small mb-4">CMIT • Devam etmek için giriş yapın</p>

                    @if (TempData["AdminError"] != null)
                    {
                        <div class="alert alert-danger py-2 small"><i class="fas fa-exclamation-circle me-1"></i>@TempData["AdminError"]</div>
                    }

                    @if (googleEnabled)
                    {
                        <a href="/Account/GoogleLogin?returnUrl=@Uri.EscapeDataString(returnUrl)" class="btn btn-google w-100 d-flex align-items-center justify-content-center gap-2 mb-3 py-2">
                            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="18" height="18" alt="" />
                            Google ile Giriş Yap
                        </a>
                        <div class="text-center text-muted small mb-3">yalnızca <strong>@@cmit.com.tr</strong> hesapları</div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2 small">Google girişi yapılandırılmamış.</div>
                    }

                    <hr class="my-3" />

                    <button class="btn btn-outline-secondary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#adminForm">
                        <i class="fas fa-user-shield me-1"></i>Admin Girişi
                    </button>

                    <div class="collapse mt-3" id="adminForm">
                        <form asp-action="AdminLogin" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="/Admin" />
                            <div class="mb-2">
                                <label class="form-label small">Kullanıcı adı (e-posta)</label>
                                <input name="username" class="form-control" placeholder="admin@cmit.com.tr" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small">Şifre</label>
                                <input name="password" type="password" class="form-control" required />
                            </div>
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-sign-in-alt me-1"></i>Admin Panele Giriş
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
